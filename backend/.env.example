# Copy this file to ".env" and fill in real values.
# .env is git-ignored so secrets never get committed.

# Port the API server listens on
PORT=4000

# PostgreSQL connection (used from Layer 2 onwards).
# Default below works for Homebrew/Postgres.app on macOS, which authenticate as
# your Mac username (no password). If your Postgres has an explicit user/password
# (e.g. a Docker container), use: postgres://USER:PASSWORD@localhost:5432/mini_coding_platform
DATABASE_URL=postgres://localhost:5432/mini_coding_platform

# --- Execution engine (Layer 4 / Layer 6) ------------------------------------
# How to run user code:
#   host   -> compile/run directly on this machine (fast; dev only, NOT secure)
#   docker -> compile/run inside a locked-down throwaway container (secure)
EXECUTION_MODE=host

# The image the docker engine compiles/runs in. The official gcc image already
# has g++. For a slimmer image, build backend/sandbox/Dockerfile and set this to
# mcp-judge:cpp
JUDGE_DOCKER_IMAGE=gcc:13

# --- Production / deployment (see DEPLOY.md) ----------------------------------
# Lock the API to your deployed frontend's origin. Leave unset for local dev
# (which allows all origins).
# CORS_ORIGIN=https://your-app.vercel.app

# SSL to PostgreSQL is auto-detected (local=off, hosted=on). Force it if needed:
# PGSSL=true
